# GitHub Personal Access Token with repo and pull_request permissions
GITHUB_TOKEN=ghp_your_token_here

# Bob Shell Wrapper API Endpoint (your hosted service)
BOB_API_ENDPOINT=https://your-bob-service.example.com

# PR details (set automatically by GitHub Actions)
PR_NUMBER=123
REPO_OWNER=your-username
REPO_NAME=your-repo

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info