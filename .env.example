# GitHub Personal Access Token (automatically provided by GitHub Actions)
GITHUB_TOKEN=ghp_your_token_here

# PR details (automatically set by GitHub Actions)
PR_NUMBER=123
REPO_OWNER=your-username
REPO_NAME=your-repo

# AI Provider Configuration
# Choose one: bob, chatgpt, claude, grok
AI_PROVIDER=bob

# Bob Configuration (when AI_PROVIDER=bob)
BOB_API_ENDPOINT=https://your-bob-service.com

# ChatGPT Configuration (when AI_PROVIDER=chatgpt)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# Claude Configuration (when AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Grok Configuration (when AI_PROVIDER=grok)
GROK_API_KEY=xai-your-grok-api-key
GROK_MODEL=grok-beta